<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Email Template 1 - Product Launch</title>
    <style type="text/css">
        body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        body, html { margin: 0; padding: 0; width: 100% !important; }
        table { border-collapse: collapse; }
        img { max-width: 100%; height: auto; display: block; }
        .container { width: 100%; max-width: 600px; margin: 0 auto; }
        .hero { background-color: #007bff; color: white; text-align: center; padding: 20px; }
        .zigzag-text { padding: 20px; background: #f8f9fa; }
        .zigzag-img { padding: 20px; }
        .cta { background: #28a745; color: white; text-align: center; padding: 20px; font-size: 18px; }
        .cta a { background: #dc3545; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; display: inline-block; }
        .footer { background: #343a40; color: white; text-align: center; padding: 20px; font-size: 12px; }
        @media screen and (min-width: 600px) {
            .zigzag-left { float: left; width: 50%; padding-right: 10px; }
            .zigzag-right { float: right; width: 50%; padding-left: 10px; }
            .content-row td { display: table-cell; }
        }
    </style>
</head>
<body>
    <table class="container" role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr><td class="hero">
            <img src="https://via.placeholder.com/600x250/007bff/ffffff?text=Product+Launch+Hero" alt="Hero Image" width="100%">
            <h1 style="margin: 10px 0; font-family: Arial, sans-serif;">New Product Launch!</h1>
        </td></tr>
        <tr class="content-row"><td>
            <div class="zigzag-img"><img src="https://via.placeholder.com/300x200/f8f9fa/333?text=Feature+Image" alt="Feature"></div>
            <div class="zigzag-text">
                <h2 style="font-family: Arial, sans-serif;">Key Feature 1</h2>
                <p>Discover the benefits. Customize this text and image.</p>
            </div>
        </td></tr>
        <tr class="content-row"><td>
            <div class="zigzag-text zigzag-left">
                <h2 style="font-family: Arial, sans-serif;">Key Feature 2</h2>
                <p>Highlight another advantage here.</p>
            </div>
            <div class="zigzag-img zigzag-right"><img src="https://via.placeholder.com/300x200/ffffff/333?text=Feature+2" alt="Feature 2"></div>
        </td></tr>
        <tr><td class="cta">
            <a href="#cta">Shop Now - Limited Time!</a>
        </td></tr>
        <tr><td class="footer">
            <p>Your Company | Unsubscribe | Privacy</p>
        </td></tr>
    </table>
</body>
</html>
